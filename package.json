{
  "name": "easy-mysql-mcp",
  "version": "1.0.3",
  "description": "High performance MySQL MCP Server using mysql2",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "easy-mysql-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mysql",
    "mysql2",
    "claude"
  ],
  "license": "MIT",
  "publishConfig": {
